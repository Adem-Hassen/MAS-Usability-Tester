SUPERVISOR_API_KEY=
SUPERVISOR_LLM_MODEL=
SUPERVISOR_TEMPERATURE=0.2

PERSONA_API_KEY=
PERSONA_LLM_MODEL=
PERSONA_TEMPERATURE=0.4

RECOMMENDER_API_KEY=
RECOMMENDER_LLM_MODEL=
RECOMMENDER_TEMPERATURE=0.1

RESOLVER_API_KEY=
RESOLVER_LLM_MODEL=
RESOLVER_TEMPERATURE=0.3

LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=2.0
LLM_MAX_CONCURRENT_CALLS=5
LLM_TPM_LIMIT=6000
LLM_INTER_REQUEST_DELAY_SECONDS=0.0


SUPERVISOR_MAX_TOKENS=2048    
PERSONA_MAX_TOKENS=512        
RECOMMENDER_MAX_TOKENS=1024   
RESOLVER_MAX_TOKENS=1024      
VERIFIER_MAX_TOKENS=1024      
LLM_MAX_OUTPUT_TOKENS=1024 


MAX_NUM_PERSONAS=3
USE_PERSONA_LIBRARY=false
PERSONA_LIBRARY_PATH=config/persona_library.yaml



PERSONA_MAX_STEPS=10
PERSONA_ACTION_TIMEOUT_SECONDS=20.0
PERSONA_PAGE_LOAD_TIMEOUT_SECONDS=30.0
PERSONA_HEADLESS=true

HDBSCAN_MIN_CLUSTER_SIZE=2
HDBSCAN_MIN_SAMPLES=1
EMBEDDING_MODEL=all-MiniLM-L6-v2
CLUSTERING_SIMILARITY_THRESHOLD=0.75


CONFLICT_STRATEGY=llm
CONFLICT_MAX_NEGOTIATION_ROUNDS=3



MAX_CORRECTION_LOOPS=3
VERIFICATION_RESOLUTION_THRESHOLD=0.8



OUTPUT_DIR=outputs
LOG_LEVEL=INFO
LOG_FORMAT=console
SAVE_ACTION_TRACES=true
SAVE_PATCHED_HTML=true